{
  "manifest_version": 3,
  "name": "TideTrack",
  "version": "2.0",
  "description": "Tracks study vs distraction time. Generates productivity reports at the end of each session.",
  "permissions": [
    "tabs",
    "storage",
    "idle"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html"
  },
  "options_page": "options.html",
  "web_accessible_resources": [
    {
      "resources": ["login.html"],
      "matches": ["<all_urls>"]
    }
  ]
}
